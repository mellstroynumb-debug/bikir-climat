{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a product in the Bikir-Climat store.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the product."
        },
        "title": {
          "type": "string",
          "description": "The title of the product."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product."
        },
        "price_pmr": {
          "type": "number",
          "description": "The price of the product in PMR (Rubles)."
        },
        "price_md": {
          "type": "number",
          "description": "The price of the product in MD (Lei)."
        },
        "images": {
          "type": "array",
          "description": "An array of image URLs for the product.",
          "items": {
            "type": "string"
          }
        },
        "specs": {
          "type": "object",
          "properties": {
            "area": {
              "type": "string"
            },
            "type": {
              "type": "string"
            },
            "inverter": {
              "type": "string",
              "enum": ["Да", "Нет"]
            },
             "power": {
              "type": "number"
            }
          },
           "required": ["area", "type", "inverter"]
        },
        "category": {
          "type": "string",
          "enum": ["cond", "service"]
        },
        "stockStatus": {
          "type": "boolean"
        }
      },
      "required": [
        "title",
        "description",
        "images",
        "specs",
        "category",
        "stockStatus"
      ]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Represents an order placed by a customer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the order."
        },
        "customerName": {
          "type": "string",
          "description": "The name of the customer who placed the order."
        },
        "phone": {
          "type": "string",
          "description": "The customer's phone number."
        },
        "address": {
          "type": "string",
          "description": "The customer's shipping address."
        },
        "items": {
          "type": "array",
          "description": "An array of product IDs in the order.",
          "items": {
            "type": "string"
          }
        },
        "totalPrice": {
          "type": "number",
          "description": "The total price of the order."
        },
        "currency": {
          "type": "string",
          "description": "The currency used for the order (PMR or MD)."
        },
        "status": {
          "type": "string",
          "description": "The status of the order (e.g., new, done)."
        }
      },
      "required": [
        "customerName",
        "phone",
        "address",
        "items",
        "totalPrice",
        "currency",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/backend/entities/Product"
      },
      "description": "Stores all product information for the Bikir-Climat store."
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/backend/entities/Order"
      },
      "description": "Stores all order information placed by customers."
    }
  }
}
