rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Products can be read by anyone, but only modified by authenticated users
    // In a real app, you'd likely have an 'admin' role check here.
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Orders can be created by anyone, but only read/updated by authenticated users.
    // Again, you'd have more granular owner/admin checks in a real app.
    match /orders/{orderId} {
      allow read, update, delete: if isSignedIn();
      allow create: if true;
    }
  }
}
